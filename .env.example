# ===========================================================================
#  VARIÁVEIS DE AMBIENTE — Template de Portfólio (F&A Works)
#  Copie este arquivo para ".env.local" e preencha os valores.
#  No deploy da Vercel, cadastre as mesmas variáveis em Settings → Environment Variables.
#  Tudo que começa com NEXT_PUBLIC_ fica visível no navegador (não coloque segredo aqui).
# ===========================================================================

# ── Notion (obrigatório) ──────────────────────────────────────────────────
# Token da sua integração do Notion (começa com "ntn_" ou "secret_").
NOTION_TOKEN=

# ID do banco de PROJETOS (o grid do portfólio). Obrigatório.
NOTION_DATABASE_ID=

# Banco da BIO (1 linha). Necessário para a página /bio.
NOTION_BIO_PAGE_ID=

# Bancos extras da bio (opcionais — deixe em branco se não for usar).
NOTION_EXPERIENCE_DB_ID=
NOTION_RELEVANT_PROJECTS_DB_ID=
NOTION_CLIENTS_DB_ID=

# ── Seus dados (aparecem no site) ─────────────────────────────────────────
NEXT_PUBLIC_SITE_NAME="Seu Nome"
NEXT_PUBLIC_SITE_ROLE="Designer & Strategist"
NEXT_PUBLIC_SITE_CITY="São Paulo"
NEXT_PUBLIC_SITE_URL="https://seudominio.com"
NEXT_PUBLIC_CONTACT_EMAIL="voce@email.com"

# ── Redes sociais (opcionais — em branco = não aparecem) ──────────────────
NEXT_PUBLIC_LINKEDIN_URL=
NEXT_PUBLIC_BEHANCE_URL=
NEXT_PUBLIC_INSTAGRAM_URL=
NEXT_PUBLIC_TWITTER_URL=

# Link de agendamento (Cal.com / Calendly). Opcional.
NEXT_PUBLIC_MEETING_URL=

# ── Resend (formulário de contato) ────────────────────────────────────────
# Necessário para o formulário /contact enviar e-mails.
RESEND_API_KEY=
# Domínio verificado no Resend (ex.: seudominio.com). Se vazio, usa o domínio
# do NEXT_PUBLIC_CONTACT_EMAIL — que só funciona se for um domínio verificado.
RESEND_FROM_DOMAIN=
